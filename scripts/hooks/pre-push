#!/usr/bin/env bash
# Pre-push hook: run smoke test before push.
# Install: copy to .git/hooks/pre-push and chmod +x
# (or symlink: ln -sf ../../scripts/hooks/pre-push .git/hooks/pre-push)

set -e
repo_root="$(git rev-parse --show-toplevel)"

if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" || "$OS" == "Windows_NT" ]]; then
    pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/smoke-test.ps1"
else
    bash "$repo_root/scripts/smoke-test.sh"
fi
